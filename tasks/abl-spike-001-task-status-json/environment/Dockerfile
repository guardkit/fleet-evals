# abl-spike-001: guardkit pinned @ pre-FEAT-9DDE 3450f602c on an arm64-native base.
# Build context tarball is generated by prepare_context.sh (not committed);
# sha256 pinned in CONTEXT.sha256.
FROM python:3.12-slim-bookworm

LABEL org.fleet-evals.suite="ablation-spike" \
      org.fleet-evals.task="abl-spike-001-task-status-json" \
      org.fleet-evals.pin="3450f602cd27093724e43f426875e431735df29f"

RUN apt-get update \
    && apt-get install -y --no-install-recommends git curl ca-certificates patch \
    && rm -rf /var/lib/apt/lists/*

# Verifier dependencies are preinstalled so tests run offline in-container.
RUN pip install --no-cache-dir pytest==8.4.1 pyyaml==6.0.2

WORKDIR /app
ADD guardkit-3450f602c.tar.gz /app/

# Give the agent a clean git baseline at the pin (git archive strips history).
RUN git init -q \
    && git add -A \
    && git -c user.email=eval@fleet-evals -c user.name=fleet-evals commit -qm "guardkit @ 3450f602c (pre-FEAT-9DDE pin)"
