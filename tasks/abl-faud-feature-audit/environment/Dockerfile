# abl-faud: guardkit pinned @ pre-FEAT-FAUD 71db6d268 on an arm64-native base.
# Build context tarball generated by prepare_context.sh (not committed);
# sha256 pinned in CONTEXT.sha256.
FROM python:3.12-slim-bookworm

LABEL org.fleet-evals.suite="phase-ablation" \
      org.fleet-evals.task="abl-faud-feature-audit" \
      org.fleet-evals.pin="71db6d2681ee874e5fee71d2909e4096a383eba0"

RUN apt-get update \
    && apt-get install -y --no-install-recommends git curl ca-certificates patch \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
ADD guardkit-71db6d268.tar.gz /app/

# Editable install exposes the guardkit-py console script the verifier drives;
# pytest preinstalled so verification is offline at verify time.
RUN pip install --no-cache-dir -e . && pip install --no-cache-dir pytest==8.4.1

# Clean git baseline at the pin (git archive strips history).
RUN git init -q \
    && git add -A \
    && git -c user.email=eval@fleet-evals -c user.name=fleet-evals commit -qm "guardkit @ 71db6d268 (pre-FEAT-FAUD pin)"
