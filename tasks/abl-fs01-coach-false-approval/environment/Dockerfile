# abl-fs01: fleet-memory pinned @ 92ef897 — the Coach-false-approved state
# (FEAT-MEM-04 wave 4 wired DeterministicWriter without its required settings
# arg; full suite RED while autobuild reported green).
# Build context tarball generated by prepare_context.sh (not committed);
# sha256 pinned in CONTEXT.sha256.
FROM python:3.12-slim-bookworm

LABEL org.fleet-evals.suite="phase-ablation" \
      org.fleet-evals.task="abl-fs01-coach-false-approval" \
      org.fleet-evals.pin="92ef8979865c469cf76c88277fb1f327a4d3954b"

RUN apt-get update \
    && apt-get install -y --no-install-recommends git curl ca-certificates patch \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
ADD fleet-memory-92ef897.tar.gz /app/

# Editable install with dev extras so the verifier's full-suite run is offline
# at verify time (network is only used here, at build).
RUN pip install --no-cache-dir -e ".[dev]"

# Clean git baseline at the pin (git archive strips history).
RUN git init -q \
    && git add -A \
    && git -c user.email=eval@fleet-evals -c user.name=fleet-evals commit -qm "fleet-memory @ 92ef897 (fs-01 pre-fix pin)"
